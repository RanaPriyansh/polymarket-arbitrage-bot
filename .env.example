# Polymarket API credentials
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_PROXY_ADDRESS=0x4D0De2cAFb9eC3d5aD4d81330Ad0112aE1814B7b  # Default CLOB proxy
POLYMARKET_WALLET_ADDRESS=your_wallet_address_here

# Bot config
DRY_RUN=true
CAPITAL=1000.0
RISK_PER_TRADE=0.02
MAX_POSITIONS=5

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Thielon wallet for revenue tracking
THIELON_AGENT_WALLET=0xYourAgentWalletAddress